# =============================================================================
# infra/aws — config template
# =============================================================================
# Copy to `terraform.tfvars` and fill in for your account:
#   cp terraform.tfvars.example terraform.tfvars
#
# `terraform.tfvars` is gitignored. `environment` is NOT set here — the
# Makefile passes it per-workspace via -var=environment=prod|dev.
# =============================================================================

# SCP-allowed region only (us-east-1 | us-east-2 | us-west-2)
region = "us-east-1"

# AWS profile that maps to the target account
aws_profile = "REPLACE_WITH_YOUR_AWS_PROFILE"

# Required tags
owner   = "REPLACE_WITH_OWNER_TAG"
project = "agent-workshop"

# ECS cluster base name (the -dev suffix is added automatically for dev)
ecs_cluster_name = "agent-workshop"

# Distinct VPC CIDR per environment (must not overlap)
vpc_cidr_by_env = {
  prod = "10.42.0.0/16"
  dev  = "10.43.0.0/16"
}

# ---- Wiz Runtime Sensor -----------------------------------------------------
# Pull key from https://app.wiz.io/tenant-info/general — pick domain
# `registry.wiz.io` (or `wizio.azurecr.io` / `wizfedramp.azurecr.us`) and copy
# the Username / Password shown.
wiz_sensor_image_pull_username = "REPLACE_WITH_WIZ_PULL_KEY_USERNAME"
wiz_sensor_image_pull_password = "REPLACE_WITH_WIZ_PULL_KEY_PASSWORD"

# Service account from Wiz portal: Settings -> Service Accounts ->
# create one with type "Sensor".
wiz_sensor_sa_client_id     = "REPLACE_WITH_WIZ_SENSOR_SA_CLIENT_ID"
wiz_sensor_sa_client_secret = "REPLACE_WITH_WIZ_SENSOR_SA_CLIENT_SECRET"

# Wiz data center, e.g. "us20" — find at
# https://app.wiz.io/tenant-info/data-center-and-regions (Tenant Data Center).
wiz_dc = "REPLACE_WITH_WIZ_DC"

# Defaults shown for clarity — both default to true in variables.tf.
# wiz_sensor_api_security_enabled     = true
# wiz_sensor_ecs_task_logging_enabled = true
